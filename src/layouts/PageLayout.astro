---
// PageLayout (L2/L3): BaseLayout + migas + el Hero canónico.
// Jerarquía: BaseLayout → PageLayout → {Product…}Layout.
// El hero es EXACTAMENTE el mismo componente que usa la home:
// misma retícula, mismo padding, misma escala tipográfica.
// Las migas se generan desde la ruta, no se escriben a mano.
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import Hero from '@components/Hero.astro';
import SectionMenu from '@components/SectionMenu.astro';
import type { SchemaInput } from '@lib/seo';

interface Props extends SchemaInput {
  title?: string;          // meta title
  description?: string;    // meta description
  path: string;            // ruta absoluta, p.ej. '/trajes/'
  h1: string;              // H1 único de la página
  h1Accent?: string;       // parte resaltada del H1
  eyebrow?: string;
  lead: string;            // subtítulo bajo el H1
  descRight: string[];     // panel de 2 párrafos, columna derecha
  meta?: string[];         // datos duros bajo el subtítulo
  crumbLabel: string;      // nombre de esta página en las migas
  parent?: { name: string; href: string };        // nivel superior (L3 → L2)
  keywords?: readonly string[];                   // tripleta propia de la página
  menuItems?: { label: string; href: string }[];  // franja de secciones de ESTA página
}

const {
  pageType,
  faqs,
  directoryItems,
  title,
  description,
  path,
  h1,
  h1Accent,
  eyebrow,
  lead,
  descRight,
  meta,
  crumbLabel,
  parent,
  keywords,
  menuItems,
} = Astro.props;

// Migas derivadas de la ruta: Inicio › [padre] › actual
const crumbs = [
  { name: 'Inicio', href: '/' },
  ...(parent ? [parent] : []),
  { name: crumbLabel, href: path },
];
---
<BaseLayout
  pageType={pageType}
  title={title}
  description={description}
  path={path}
  keywords={keywords}
  faqs={faqs}
  directoryItems={directoryItems}
  breadcrumbs={crumbs}
>
  <Breadcrumbs items={crumbs} />

  <Hero
    eyebrow={eyebrow}
    title={h1}
    accent={h1Accent}
    subtitle={lead}
    descRight={descRight}
    meta={meta}
  />

  <SectionMenu items={menuItems} />

  <slot />
</BaseLayout>
