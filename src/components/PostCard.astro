---
// PostCard: tarjeta de artículo. Hereda el lenguaje visual de
// CategoryCard (borde, elevación al hover, CTA con flecha) para
// que el blog no parezca de otro sitio. NO emite schema:
// el índice padre emite el ItemList (regla B3).
// Variante "wide": artículo destacado, a dos columnas.
import { categoriaNombre, formatFechaCorta } from '@lib/blog';

interface Props {
  href: string;
  title: string;
  resumen: string;
  categoria: string;
  fecha: Date;
  lectura: number;
  destacado?: boolean;
  wide?: boolean;
  index?: number;
}
const { href, title, resumen, categoria, fecha, lectura, destacado = false, wide = false, index = 0 } = Astro.props;
---
<a class:list={['post-card', { 'post-card--wide': wide }]} href={href}>
  <div class="post-card__head">
    <span class="post-card__cat">{categoriaNombre(categoria)}</span>
    {destacado && <span class="post-card__badge">Destacado</span>}
  </div>
  <h3 class="post-card__title">{title}</h3>
  <p class="post-card__resumen">{resumen}</p>
  <div class="post-card__foot">
    <span class="post-card__meta">
      <time datetime={fecha.toISOString()}>{formatFechaCorta(fecha)}</time>
      <span aria-hidden="true">·</span>
      <span>{lectura} min de lectura</span>
    </span>
    <span class="post-card__cta">
      Leer artículo
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    </span>
  </div>
  <span class="post-card__n" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
</a>

<style>
  .post-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    height: 100%;
    padding: 1.5rem 1.5rem 1.3rem;
    background: var(--color-white);
    border: var(--border);
    border-top: 3px solid var(--color-primary);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--color-dark);
    overflow: hidden;
    transition: box-shadow 0.22s ease, transform 0.22s ease, border-color 0.22s ease;
  }
  .post-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
    border-color: rgb(200 16 46 / 0.35);
    border-top-color: var(--color-primary);
  }

  .post-card__head { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
  .post-card__cat {
    font-size: 0.68rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-primary);
  }
  .post-card__badge {
    padding: 0.14rem 0.5rem;
    border-radius: 2px;
    background: var(--color-accent);
    color: var(--color-dark);
    font-size: 0.64rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .post-card__title {
    margin: 0;
    font-size: var(--fs-h3);
    line-height: 1.28;
    text-wrap: balance;
  }
  .post-card:hover .post-card__title { color: var(--color-primary); }
  .post-card__resumen {
    margin: 0;
    flex: 1;
    color: var(--color-gray);
    font-size: 0.88rem;
    line-height: 1.6;
  }

  .post-card__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 0.3rem;
    padding-top: 0.85rem;
    border-top: var(--border);
  }
  .post-card__meta {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--color-gray-soft);
    font-size: 0.76rem;
    font-weight: 600;
  }
  .post-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-primary);
    font-weight: 800;
    font-size: 0.83rem;
  }
  .post-card__cta svg { transition: transform 0.22s ease; }
  .post-card:hover .post-card__cta svg { transform: translateX(4px); }

  .post-card__n {
    position: absolute;
    right: 0.9rem;
    top: 0.55rem;
    font-size: 2.4rem;
    font-weight: 800;
    line-height: 1;
    color: var(--color-light);
    letter-spacing: var(--tracking-tight);
    pointer-events: none;
  }

  /* Destacado a dos columnas: mismo componente, otra retícula */
  .post-card--wide {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(0, 1fr);
    grid-template-areas: 'head foot' 'title foot' 'resumen foot';
    align-content: start;
    gap: 0.8rem clamp(1.5rem, 3vw, 3rem);
    padding: clamp(1.6rem, 2.4vw, 2.4rem);
  }
  .post-card--wide .post-card__head { grid-area: head; }
  .post-card--wide .post-card__title { grid-area: title; font-size: clamp(1.35rem, 2vw, 1.85rem); }
  .post-card--wide .post-card__resumen { grid-area: resumen; font-size: 0.95rem; }
  /* El destacado cierra con un panel oscuro: el mismo recurso
     visual del hero y de la tarjeta de cotización. Integra la
     tarjeta al lenguaje del sitio en vez de dejar un hueco. */
  .post-card--wide .post-card__foot {
    grid-area: foot;
    flex-direction: column;
    align-items: stretch;
    justify-content: center;
    gap: 1rem;
    margin: 0;
    padding: 1.5rem;
    border: 0;
    border-radius: var(--radius);
    background: var(--color-ink);
    height: 100%;
    position: relative;
    overflow: hidden;
  }
  .post-card--wide .post-card__foot::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 4px;
    background: repeating-linear-gradient(115deg, var(--color-accent) 0 14px, var(--color-ink-soft) 14px 28px);
  }
  .post-card--wide .post-card__meta { color: #b9bec5; font-size: 0.78rem; }
  .post-card--wide .post-card__cta {
    justify-content: center;
    padding: 0.8rem 1.2rem;
    border-radius: var(--radius);
    background: var(--color-primary);
    color: #fff;
    font-size: 0.88rem;
  }
  .post-card:hover .post-card--wide .post-card__cta,
  .post-card--wide:hover .post-card__cta { background: var(--color-primary-dark); }
  /* El destacado no numera: es uno solo y el número chocaba
     con el panel oscuro. */
  .post-card--wide .post-card__n { display: none; }

  @media (max-width: 860px) {
    .post-card--wide {
      grid-template-columns: 1fr;
      grid-template-areas: 'head' 'title' 'resumen' 'foot';
    }
    .post-card--wide .post-card__foot {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      padding: 1rem 1.2rem;
      height: auto;
    }
  }
</style>
