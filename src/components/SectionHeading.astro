---
// SectionHeading: eyebrow con barra de acento + título (H2) +
// descripción. Un solo H1 en el hero; H2 en cada sección.
// Variante "duo": título izquierda, 2 párrafos derecha.
// Un solo componente para todos los títulos: cero diseño duplicado.
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  duo?: string[];
  dark?: boolean;
}
const { eyebrow, title, description, duo, dark = false } = Astro.props;
---
<div class:list={['sec-heading', { 'sec-heading--dark': dark, 'sec-heading--duo': !!duo }]}>
  <div class="sec-heading__main">
    <p class="eyebrow sec-heading__eyebrow">{eyebrow}</p>
    <h2>{title}</h2>
    {description && <p class="sec-heading__desc">{description}</p>}
  </div>
  {duo && (
    <div class="sec-heading__duo">
      {duo.map((p) => <p>{p}</p>)}
    </div>
  )}
</div>

<style>
  .sec-heading { margin-bottom: clamp(2rem, 3.5vw, 3.2rem); }
  .sec-heading--duo {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
  }
  h2 { font-size: var(--fs-h2); margin: 0 0 0.7rem; text-wrap: balance; }
  .sec-heading__desc, .sec-heading__duo p { color: var(--color-gray); margin: 0 0 0.9rem; font-size: var(--fs-lead); }
  .sec-heading__duo p { font-size: var(--fs-body); }
  .sec-heading__duo p:last-child { margin-bottom: 0; }

  .sec-heading--dark h2 { color: var(--color-white); }
  .sec-heading--dark .sec-heading__eyebrow { color: var(--color-accent); }
  .sec-heading--dark .sec-heading__eyebrow::before { background: var(--color-accent); }
  .sec-heading--dark .sec-heading__desc, .sec-heading--dark .sec-heading__duo p { color: #b9bec5; }

  @media (max-width: 900px) { .sec-heading--duo { grid-template-columns: 1fr; gap: 1rem; } }
</style>
