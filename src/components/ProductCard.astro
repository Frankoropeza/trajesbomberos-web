---
// ProductCard: pieza cotizable dentro de una familia de traje.
// Estructura fija: media 16:10 con índice · cuerpo (título,
// descripción, chips) · ficha corta "Se especifica" · CTA
// full-width. Altura uniforme para que la retícula no baile.
// NO emite schema (regla B3: el ItemList lo emite la página).
import { WA_MESSAGES } from '@config/site';
import { waUrl } from '@lib/wa';
import { piezaPorNombreCard } from '@lib/piezas';

interface Props {
  nombre: string;
  desc: string;
  chips: string[];
  spec?: string;
  img: string;
  alt: string;
  index?: number;
}
const { nombre, desc, chips, spec, img, alt, index = 0 } = Astro.props;
const eager = index < 3;
// Si la pieza tiene ficha L4 publicada, la tarjeta lleva a la ficha
// y el CTA de WhatsApp pasa a segundo plano.
const ficha = piezaPorNombreCard(nombre);
const fichaHref = ficha ? `/trajes/${ficha.familia}/${ficha.slug}/` : null;
---
<article class="prod">
  <div class="prod__media">
    <img
      src={img}
      alt={alt}
      width="640"
      height="400"
      loading={eager ? 'eager' : 'lazy'}
      decoding="async"
    />
    <span class="prod__n">{String(index + 1).padStart(2, '0')}</span>
  </div>

  <div class="prod__body">
    <h3>{nombre}</h3>
    <p class="prod__desc">{desc}</p>

    <div class="prod__chips">
      {chips.map((c) => <span class="chip">{c}</span>)}
    </div>

    {spec && (
      <dl class="prod__spec">
        <dt>Se especifica</dt>
        <dd>{spec}</dd>
      </dl>
    )}

    <div class="prod__actions">
      {fichaHref ? (
        <a class="prod__cta prod__cta--ficha" href={fichaHref}>
          {nombre}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      ) : (
        <a
          class="prod__cta"
          href={waUrl(WA_MESSAGES.categoria(nombre))}
          target="_blank"
          rel="noopener nofollow"
          aria-label={`Cotizar ${nombre} por WhatsApp`}
        >
          <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2zm0 18.2a8.2 8.2 0 0 1-4.2-1.2l-.3-.2-3 .8.8-2.9-.2-.3A8.2 8.2 0 1 1 12 20.2z"/></svg>
          Cotizar esta pieza
        </a>
      )}
    </div>
  </div>
</article>

<style>
  .prod {
    display: flex;
    flex-direction: column;
    background: var(--color-white);
    border: var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    height: 100%;
  }
  .prod:hover {
    box-shadow: var(--shadow);
    border-color: rgb(200 16 46 / 0.4);
  }

  .prod__media {
    position: relative;
    aspect-ratio: 16 / 10;
    background: var(--color-light);
    border-bottom: var(--border);
    overflow: hidden;
  }
  .prod__media img { width: 100%; height: 100%; object-fit: cover; }
  .prod__n {
    position: absolute;
    top: 0;
    left: 0;
    min-width: 38px;
    padding: 0.35rem 0.55rem;
    background: var(--color-ink);
    color: var(--color-accent);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-align: center;
  }

  .prod__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.15rem 1.25rem 1.25rem;
  }
  h3 {
    margin: 0 0 0.5rem;
    font-size: 1.02rem;
    line-height: 1.25;
    text-wrap: balance;
  }
  .prod__desc {
    margin: 0 0 0.9rem;
    color: var(--color-gray);
    font-size: 0.86rem;
    line-height: 1.55;
  }
  .prod__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-bottom: 0.9rem;
  }

  .prod__spec {
    margin: 0 0 1.1rem;
    padding: 0.75rem 0.9rem;
    background: var(--color-light);
    border-left: 3px solid var(--color-accent);
    border-radius: 0 var(--radius) var(--radius) 0;
    flex: 1;
  }
  .prod__spec dt {
    font-size: 0.66rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-gray-soft);
    margin-bottom: 0.25rem;
  }
  .prod__spec dd {
    margin: 0;
    font-size: 0.81rem;
    line-height: 1.5;
    color: var(--color-gray);
  }

  .prod__actions { margin-top: auto; display: grid; gap: 0.5rem; }
  .prod__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.7rem 1rem;
    min-height: 46px;
    border-radius: var(--radius);
    background: var(--color-wa);
    color: #fff;
    font-weight: 700;
    font-size: 0.88rem;
    text-decoration: none;
    transition: background 0.18s ease;
  }
  .prod__cta:hover { background: var(--color-wa-dark); }

  /* Con ficha publicada: primario a la ficha, WhatsApp secundario */
  /* Con ficha publicada, el CTA lleva el nombre del producto:
     mejor anchor text que un "ver más" genérico. */
  .prod__cta--ficha {
    background: var(--color-primary);
    text-align: left;
    line-height: 1.25;
    padding-block: 0.8rem;
  }
  .prod__cta--ficha:hover { background: var(--color-primary-dark); }
</style>
