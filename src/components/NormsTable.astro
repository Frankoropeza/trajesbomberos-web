---
// NormsTable: tabla de 3 columnas para mapear RESPALDO (normas,
// garantías, certificaciones). Regla del sistema: cero datos
// fabricados — solo normas/certificaciones reales. Nunca cites
// una norma o certificación que no tengas.
interface Props {
  columns: [string, string, string];
  rows: [string, string, string][];
  note?: string;
}
const { columns, rows, note } = Astro.props;
---
<div class="normstable">
  <div class="normstable__scroll" tabindex="0" role="region" aria-label="Respaldo">
    <table>
      <thead>
        <tr>{columns.map((c) => <th scope="col">{c}</th>)}</tr>
      </thead>
      <tbody>
        {rows.map(([a, b, c]) => (
          <tr>
            <th scope="row">{a}</th>
            <td>{b}</td>
            <td>{c}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  {note && <p class="normstable__note">{note}</p>}
</div>

<style>
  .normstable__scroll { overflow-x: auto; border: var(--border); border-radius: var(--radius-lg); background: var(--color-white); }
  table { width: 100%; border-collapse: collapse; min-width: 620px; }
  th, td { padding: 1.05rem 1.3rem; text-align: left; border-bottom: var(--border); font-size: 0.92rem; vertical-align: top; }
  thead th {
    background: var(--color-white);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    font-weight: 800;
    color: var(--color-gray-soft);
    border-bottom-width: 2px;
  }
  tbody th { font-weight: 800; white-space: nowrap; }
  td { color: var(--color-gray); }
  tbody tr:last-child th, tbody tr:last-child td { border-bottom: 0; }
  .normstable__note { color: var(--color-gray); font-size: 0.88rem; margin: 1.1rem 0 0; max-width: 72ch; }
</style>
