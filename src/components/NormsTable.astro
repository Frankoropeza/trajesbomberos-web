---
// NormsTable: tabla de 3 columnas para mapear RESPALDO (normas,
// garantías, certificaciones). Regla del sistema: cero datos
// fabricados — solo normas/certificaciones reales. Nunca cites
// una norma o certificación que no tengas.
interface Props {
  columns: [string, string, string];
  rows: [string, string, string][];
  note?: string;
}
const { columns, rows, note } = Astro.props;
---
<div class="normstable">
  <div class="normstable__scroll" tabindex="0" role="region" aria-label="Respaldo">
    <table>
      <thead>
        <tr>{columns.map((c) => <th scope="col">{c}</th>)}</tr>
      </thead>
      <tbody>
        {rows.map(([a, b, c]) => (
          <tr>
            <th scope="row">{a}</th>
            <td>{b}</td>
            <td>{c}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  {note && <p class="normstable__note">{note}</p>}
</div>

<style>
  .normstable__scroll { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; min-width: 560px; background: var(--color-white); border-radius: var(--radius); overflow: hidden; border: 1px solid var(--color-gray-light); }
  th, td { padding: 0.9rem 1rem; text-align: left; border-bottom: 1px solid var(--color-gray-light); font-size: 0.92rem; }
  thead th { background: var(--color-light); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.04em; }
  tbody th { font-weight: 700; white-space: nowrap; }
  td { color: var(--color-gray); }
  tbody tr:last-child th, tbody tr:last-child td { border-bottom: 0; }
  .normstable__note { color: var(--color-gray); font-size: 0.88rem; margin: 1rem 0 0; }
</style>
