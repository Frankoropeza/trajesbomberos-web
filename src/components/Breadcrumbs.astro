---
// Breadcrumbs: se generan desde la ruta de la página, nunca se
// escriben a mano. El schema BreadcrumbList NO se emite aquí
// (regla B3: único emisor = BaseLayout).
interface Props {
  items: { name: string; href: string }[];
}
const { items } = Astro.props;
---
<nav class="crumbs" aria-label="Ruta de navegación">
  <div class="container">
    <ol>
      {items.map((item, i) => (
        <li>
          {i < items.length - 1 ? (
            <a href={item.href}>{item.name}</a>
          ) : (
            <span aria-current="page">{item.name}</span>
          )}
        </li>
      ))}
    </ol>
  </div>
</nav>

<style>
  .crumbs { background: var(--color-white); border-bottom: var(--border); }
  ol {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0.85rem 0;
    font-size: 0.82rem;
  }
  li { display: flex; align-items: center; gap: 0.5rem; }
  li + li::before {
    content: '›';
    color: var(--color-gray-soft);
  }
  a { color: var(--color-gray); text-decoration: none; }
  a:hover { color: var(--color-primary); }
  span { color: var(--color-dark); font-weight: 700; }
</style>
