---
// FAB de WhatsApp. 52px en móvil + safe-area (mobile.css → .wa-float).
// Regla D4: el enlace se genera con waUrl (SSoT CONTACT.whatsapp).
import { WA_MESSAGES } from '@config/site';
import { waUrl } from '@lib/wa';
---
<a
  class="wa-float"
  href={waUrl(WA_MESSAGES.informacion)}
  target="_blank"
  rel="noopener nofollow"
  aria-label="Escríbenos por WhatsApp"
>
  <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2zm0 18.2a8.2 8.2 0 0 1-4.2-1.2l-.3-.2-3 .8.8-2.9-.2-.3A8.2 8.2 0 1 1 12 20.2zm4.6-6.1c-.3-.1-1.5-.7-1.7-.8-.2-.1-.4-.1-.6.1l-.8 1c-.1.2-.3.2-.5.1a6.7 6.7 0 0 1-3.3-2.9c-.3-.4 0-.6.2-.8l.4-.5c.1-.2.1-.3.2-.5s0-.4 0-.5l-.8-1.9c-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3-.9.9-1.2 2-.8 3.2a11.4 11.4 0 0 0 4.3 5.2c1.6 1 2.8 1.4 3.8 1.2.8-.1 1.7-.7 2-1.4.2-.6.2-1.2.1-1.3-.1-.2-.3-.2-.7-.4z"/>
  </svg>
</a>

<style>
  .wa-float {
    position: fixed;
    bottom: 1.4rem;
    right: 1.4rem;
    z-index: 90;
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--color-wa);
    color: #fff;
    box-shadow: var(--shadow-lg);
    transition: background 0.15s linear;
  }
  .wa-float:hover { background: var(--color-wa-dark); }
</style>
