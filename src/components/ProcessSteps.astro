---
// ProcessSteps: proceso de trabajo en 4–5 pasos numerados sobre
// fondo tinta — contraste que rompe la página y da ritmo.
// Describe el proceso REAL, sin tiempos garantizados que no se cumplan.
interface Paso { title: string; desc: string; }
interface Props { pasos: Paso[]; }
const { pasos } = Astro.props;
---
<ol class="steps-grid">
  {pasos.map((p, i) => (
    <li class="step">
      <span class="step__num">{String(i + 1).padStart(2, '0')}</span>
      <h3>{p.title}</h3>
      <p>{p.desc}</p>
    </li>
  ))}
</ol>

<style>
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
    counter-reset: step;
  }
  .step {
    padding: 0 clamp(1rem, 2vw, 2.2rem);
    border-left: 1px solid rgb(255 255 255 / 0.14);
    position: relative;
  }
  .step:first-child { border-left: 0; padding-left: 0; }
  .step__num {
    display: block;
    font-size: 2.4rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: var(--tracking-tight);
    color: var(--color-accent);
    margin-bottom: 0.7rem;
  }
  h3 { margin: 0 0 0.35rem; font-size: 1rem; color: var(--color-white); }
  p { margin: 0; font-size: 0.85rem; color: #b9bec5; line-height: 1.55; }

  @media (max-width: 1024px) {
    .steps-grid { grid-template-columns: repeat(3, 1fr); row-gap: 2rem; }
    .step:nth-child(3n + 1) { border-left: 0; padding-left: 0; }
  }
  @media (max-width: 640px) {
    .steps-grid { grid-template-columns: repeat(2, 1fr); }
    .step:nth-child(odd) { border-left: 0; padding-left: 0; }
  }
</style>
