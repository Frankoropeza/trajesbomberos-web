---
// CategoryFeature: spotlight de categoría. 2 columnas: texto
// estructurado (eyebrow + título + description + features[] con
// check + brands en pills + CTA flecha) | galería de 3 imágenes
// (1 grande + 2 pequeñas). flip=true invierte columnas. VENDE la
// categoría antes de entrar — va en la home, no en la categoría.
// Data-driven: cero contenido hardcodeado. Pills = solo texto.
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  features: string[];       // admite **negritas** simples al inicio
  brands?: string[];
  ctaLabel: string;
  ctaHref: string;
  images: { src: string; alt: string }[];  // [grande, chica, chica]
  flip?: boolean;
  external?: boolean;
}
const { eyebrow, title, description, features, brands = [], ctaLabel, ctaHref, images, flip = false, external = false } = Astro.props;
---
<div class:list={['feature-grid', { 'feature-grid--flip': flip }]}>
  <div class="feature-text">
    <p class="feature-eyebrow">{eyebrow}</p>
    <h3>{title}</h3>
    <p class="feature-desc">{description}</p>
    <ul class="feature-list">
      {features.map((f) => <li>{f}</li>)}
    </ul>
    {brands.length > 0 && (
      <div class="feature-brands">
        {brands.map((b) => <span class="chip">{b}</span>)}
      </div>
    )}
    <a class="feature-cta" href={ctaHref} target={external ? '_blank' : undefined} rel={external ? 'noopener' : undefined}>{ctaLabel} →</a>
  </div>
  <div class="feature-gallery">
    {images.slice(0, 3).map((img, i) => (
      <img
        src={img.src}
        alt={img.alt}
        width={i === 0 ? 800 : 400}
        height={i === 0 ? 450 : 225}
        loading="lazy"
        decoding="async"
        class:list={[i === 0 ? 'feature-img--big' : 'feature-img--small']}
      />
    ))}
  </div>
</div>

<style>
  .feature-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .feature-grid--flip .feature-text { order: 2; }
  .feature-grid--flip .feature-gallery { order: 1; }
  .feature-eyebrow {
    margin: 0 0 0.4rem;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-primary);
  }
  h3 { font-size: 1.6rem; margin: 0 0 0.7rem; line-height: 1.2; }
  .feature-desc { color: var(--color-gray); margin: 0 0 1rem; }
  .feature-list { list-style: none; margin: 0 0 1rem; padding: 0; display: grid; gap: 0.5rem; }
  .feature-list li { padding-left: 1.7rem; position: relative; color: var(--color-gray); }
  .feature-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: 800;
  }
  .feature-brands { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1.2rem; }
  .feature-cta { font-weight: 700; text-decoration: none; color: var(--color-primary); }
  .feature-gallery {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.9rem;
  }
  .feature-gallery img { border-radius: var(--radius); width: 100%; height: 100%; object-fit: cover; }
  .feature-img--big { grid-column: 1 / -1; aspect-ratio: 16 / 9; }
  .feature-img--small { aspect-ratio: 16 / 9; }
</style>
