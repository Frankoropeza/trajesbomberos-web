---
// CategoryFeature: spotlight de categoría. 2 columnas: texto
// estructurado (eyebrow + título + description + features[] con
// check + brands en pills + CTA flecha) | galería de 3 imágenes
// (1 grande + 2 pequeñas). flip=true invierte columnas. VENDE la
// categoría antes de que el visitante entre.
// Data-driven: cero contenido hardcodeado. Pills = solo texto.
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  features: string[];
  brands?: string[];
  ctaLabel: string;
  ctaHref: string;
  images: { src: string; alt: string }[];  // [grande, chica, chica]
  flip?: boolean;
  external?: boolean;
}
const { eyebrow, title, description, features, brands = [], ctaLabel, ctaHref, images, flip = false, external = false } = Astro.props;
---
<div class:list={['feature-grid', { 'feature-grid--flip': flip }]}>
  <div class="feature-text">
    <p class="eyebrow">{eyebrow}</p>
    <h3>{title}</h3>
    <p class="feature-desc">{description}</p>
    <ul class="feature-list">
      {features.map((f) => <li>{f}</li>)}
    </ul>
    {brands.length > 0 && (
      <div class="feature-brands">
        {brands.map((b) => <span class="chip">{b}</span>)}
      </div>
    )}
    <a class="btn" href={ctaHref} target={external ? '_blank' : undefined} rel={external ? 'noopener' : undefined}>{ctaLabel}</a>
  </div>
  <div class="feature-gallery">
    {images.slice(0, 3).map((img, i) => (
      <img
        src={img.src}
        alt={img.alt}
        width={i === 0 ? 800 : 400}
        height={i === 0 ? 500 : 300}
        loading="lazy"
        decoding="async"
        class:list={[i === 0 ? 'feature-img--big' : 'feature-img--small']}
      />
    ))}
  </div>
</div>

<style>
  .feature-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
  }
  .feature-grid--flip .feature-text { order: 2; }
  .feature-grid--flip .feature-gallery { order: 1; }
  h3 { font-size: var(--fs-h2); margin: 0 0 0.8rem; text-wrap: balance; }
  .feature-desc { color: var(--color-gray); margin: 0 0 1.4rem; font-size: var(--fs-lead); }
  .feature-list { list-style: none; margin: 0 0 1.4rem; padding: 0; display: grid; gap: 0.65rem; }
  .feature-list li { padding-left: 1.9rem; position: relative; color: var(--color-dark); font-size: 0.94rem; }
  .feature-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    top: 0.1rem;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--color-primary-light);
    border: 1px solid rgb(200 16 46 / 0.28);
    color: var(--color-primary);
    font-size: 0.72rem;
    font-weight: 800;
    line-height: 1;
  }
  .feature-brands { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-bottom: 1.7rem; }

  .feature-gallery {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }
  /* aspect-ratio 16:10 = el mismo de las imágenes, así cover no recorta */
  .feature-gallery img {
    border-radius: var(--radius-lg);
    border: var(--border);
    width: 100%;
    height: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }
  .feature-img--big { grid-column: 1 / -1; }

  @media (max-width: 900px) {
    .feature-grid, .feature-grid--flip .feature-text, .feature-grid--flip .feature-gallery { grid-template-columns: 1fr; order: initial; }
  }
</style>
