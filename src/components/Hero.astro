---
// Hero canónico del sitio. Se usa IGUAL en L1, L2 y L3.
// Dos columnas: izquierda title + accent (H1 ÚNICO, con la kw
// principal) + subtitle; derecha descRight[] como panel de
// contexto. Los CTA no viven aquí: "el hero presenta, la franja
// convierte" (van en SectionMenu, justo debajo).
// `compact` solo reduce el padding en páginas internas: el
// diseño, la retícula y la banda reflectante son los mismos.
interface Props {
  eyebrow?: string;
  title: string;
  accent?: string;
  subtitle: string;
  descRight: string[];
  compact?: boolean;
}
const { eyebrow, title, accent, subtitle, descRight, compact = false } = Astro.props;
---
<section class:list={['hero', { 'hero--compact': compact }]}>
  <div class="hero__stripes" aria-hidden="true"></div>
  <div class="container hero-grid">
    <div class="hero-left">
      {eyebrow && <p class="hero__eyebrow">{eyebrow}</p>}
      <h1>{title}{accent && <> <span class="hero-accent">{accent}</span></>}</h1>
      <p class="hero-subtitle">{subtitle}</p>
    </div>
    <div class="hero-right">
      <div class="hero-panel">
        {descRight.map((p) => <p>{p}</p>)}
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(120% 100% at 82% 0%, rgba(200, 16, 46, 0.28) 0%, transparent 62%),
      linear-gradient(180deg, var(--color-ink) 0%, var(--color-ink-soft) 100%);
    color: var(--color-white);
    padding-block: clamp(3.5rem, 7vw, 7rem);
  }
  .hero--compact { padding-block: clamp(2.8rem, 5vw, 4.8rem); }

  /* Banda reflectante de alta visibilidad (código visual bombero) */
  .hero__stripes {
    position: absolute;
    inset: auto 0 0 0;
    height: 6px;
    background: repeating-linear-gradient(
      115deg,
      var(--color-accent) 0 26px,
      var(--color-ink-soft) 26px 52px
    );
    opacity: 0.9;
  }
  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }
  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin: 0 0 1rem;
    font-size: var(--fs-xs);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-accent);
  }
  .hero__eyebrow::before {
    content: '';
    width: 28px;
    height: 3px;
    background: var(--color-accent);
  }
  h1 {
    font-size: var(--fs-h1);
    margin: 0 0 1.1rem;
    text-wrap: balance;
  }
  .hero--compact h1 { font-size: clamp(1.9rem, 3.6vw, 3.2rem); }
  .hero-accent { color: var(--color-accent); }
  .hero-subtitle {
    font-size: var(--fs-lead);
    color: #c8ccd2;
    margin: 0;
  }
  .hero-panel {
    border-left: 3px solid var(--color-primary);
    padding: 0.2rem 0 0.2rem 1.6rem;
  }
  .hero-panel p {
    color: #b9bec5;
    font-size: var(--fs-sm);
    margin: 0 0 1rem;
  }
  .hero-panel p:last-child { margin-bottom: 0; }

  @media (max-width: 1024px) {
    .hero-grid { grid-template-columns: 1fr; gap: 2rem; }
    .hero-panel { border-left: 0; border-top: 3px solid var(--color-primary); padding: 1.2rem 0 0; }
  }
</style>
