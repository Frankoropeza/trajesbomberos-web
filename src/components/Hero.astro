---
// Hero canónico del sitio — idéntico en L1, L2 y L3.
// Dos columnas: izquierda title + accent (H1 ÚNICO, con la kw
// principal), subtitle y fila de datos duros; derecha descRight[]
// como panel de contexto. Los CTA no viven aquí: "el hero
// presenta, la franja convierte" (van en SectionMenu, debajo).
interface Props {
  eyebrow?: string;
  title: string;
  accent?: string;
  subtitle: string;
  descRight: string[];
  meta?: string[];
}
const { eyebrow, title, accent, subtitle, descRight, meta = [] } = Astro.props;
---
<section class="hero">
  <div class="hero__stripes" aria-hidden="true"></div>
  <div class="container hero-grid">
    <div class="hero-left">
      {eyebrow && <p class="hero__eyebrow">{eyebrow}</p>}
      <h1>{title}{accent && <> <span class="hero-accent">{accent}</span></>}</h1>
      <p class="hero-subtitle">{subtitle}</p>
      {meta.length > 0 && (
        <ul class="hero-meta">
          {meta.map((m) => <li>{m}</li>)}
        </ul>
      )}
    </div>
    <div class="hero-right">
      <div class="hero-panel">
        {descRight.map((p) => <p>{p}</p>)}
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(120% 100% at 82% 0%, rgba(200, 16, 46, 0.28) 0%, transparent 62%),
      linear-gradient(180deg, var(--color-ink) 0%, var(--color-ink-soft) 100%);
    color: var(--color-white);
    padding-block: clamp(3.5rem, 7vw, 7rem);
  }
  /* Banda reflectante de alta visibilidad (código visual bombero) */
  .hero__stripes {
    position: absolute;
    inset: auto 0 0 0;
    height: 6px;
    background: repeating-linear-gradient(
      115deg,
      var(--color-accent) 0 26px,
      var(--color-ink-soft) 26px 52px
    );
    opacity: 0.9;
  }
  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }
  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin: 0 0 1rem;
    font-size: var(--fs-xs);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-accent);
  }
  .hero__eyebrow::before {
    content: '';
    width: 28px;
    height: 3px;
    background: var(--color-accent);
  }
  h1 {
    font-size: var(--fs-h1);
    margin: 0 0 1.1rem;
    text-wrap: balance;
  }
  .hero-accent { color: var(--color-accent); }
  .hero-subtitle {
    font-size: var(--fs-lead);
    color: #c8ccd2;
    margin: 0;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.55rem 1.5rem;
    list-style: none;
    margin: 1.7rem 0 0;
    padding: 1.2rem 0 0;
    border-top: 1px solid rgb(255 255 255 / 0.14);
  }
  .hero-meta li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #d6dae0;
  }
  .hero-meta li::before {
    content: '';
    width: 6px;
    height: 6px;
    background: var(--color-accent);
    flex-shrink: 0;
  }

  .hero-panel {
    border-left: 3px solid var(--color-primary);
    padding: 0.2rem 0 0.2rem 1.6rem;
  }
  .hero-panel p {
    color: #b9bec5;
    font-size: var(--fs-sm);
    margin: 0 0 1rem;
  }
  .hero-panel p:last-child { margin-bottom: 0; }

  @media (max-width: 1024px) {
    .hero-grid { grid-template-columns: 1fr; gap: 2rem; }
    .hero-panel { border-left: 0; border-top: 3px solid var(--color-primary); padding: 1.2rem 0 0; }
  }
</style>
