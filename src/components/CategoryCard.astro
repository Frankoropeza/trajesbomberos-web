---
// CategoryCard: tarjeta reusable (catálogo Y beneficios — la guía
// reusa el mismo componente). imageAlt describe la imagen, el
// título es <h3> (jerarquía H1→H2→H3), los chips anticipan piezas.
// Las 4 primeras cargan eager (auto por index); NO emite schema
// (regla B3: el grid padre emite ItemList via directorySchema).
interface Props {
  href: string;
  image: string;
  imageAlt: string;
  title: string;
  desc: string;
  badge?: string;
  chips?: string[];
  ctaLabel?: string;
  index?: number;
  external?: boolean;
}
const { href, image, imageAlt, title, desc, badge, chips = [], ctaLabel = 'Ver más', index = 0, external = false } = Astro.props;
const eager = index < 4;
---
<a
  class="cat-card"
  href={href}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener' : undefined}
>
  <div class="cat-card__media">
    <img
      src={image}
      alt={imageAlt}
      width="640"
      height="360"
      loading={eager ? 'eager' : 'lazy'}
      decoding="async"
      fetchpriority={index === 0 ? 'high' : undefined}
    />
    {badge && <span class="cat-card__badge">{badge}</span>}
  </div>
  <div class="cat-card__body">
    <h3>{title}</h3>
    <p>{desc}</p>
    {chips.length > 0 && (
      <div class="cat-card__chips">
        {chips.map((c) => <span class="chip">{c}</span>)}
      </div>
    )}
    <span class="cat-card__cta">{ctaLabel} →</span>
  </div>
</a>

<style>
  .cat-card {
    display: flex;
    flex-direction: column;
    background: var(--color-white);
    border: 1px solid var(--color-gray-light);
    border-radius: var(--radius);
    overflow: hidden;
    text-decoration: none;
    color: var(--color-dark);
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .cat-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-3px); }
  .cat-card__media { position: relative; aspect-ratio: 16 / 9; background: var(--color-light); }
  .cat-card__media img { width: 100%; height: 100%; object-fit: cover; }
  .cat-card__badge {
    position: absolute;
    top: 0.6rem;
    left: 0.6rem;
    background: var(--color-accent);
    color: var(--color-dark);
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
  }
  .cat-card__body { display: flex; flex-direction: column; gap: 0.5rem; padding: 1.1rem; flex: 1; }
  h3 { margin: 0; font-size: 1.05rem; }
  p { margin: 0; color: var(--color-gray); font-size: 0.9rem; flex: 1; }
  .cat-card__chips { display: flex; flex-wrap: wrap; gap: 0.35rem; }
  .cat-card__cta { color: var(--color-primary); font-weight: 700; font-size: 0.9rem; }
</style>
