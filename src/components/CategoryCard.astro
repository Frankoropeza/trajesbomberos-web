---
// CategoryCard: tarjeta reusable (catálogo, beneficios, listados
// de familias). imageAlt describe la imagen, el título es <h3>
// (jerarquía H1→H2→H3) y los chips anticipan las piezas.
// Las 4 primeras cargan eager (auto por index); NO emite schema
// (regla B3: el grid padre emite ItemList via directorySchema).
// `current` = la familia en la que ya estás: se pinta como
// tarjeta de estado, sin enlace, para no enlazar a sí misma.
interface Props {
  href: string;
  image: string;
  imageAlt: string;
  title: string;
  desc: string;
  badge?: string;
  chips?: string[];
  ctaLabel?: string;
  index?: number;
  external?: boolean;
  current?: boolean;
}
const {
  href,
  image,
  imageAlt,
  title,
  desc,
  badge,
  chips = [],
  ctaLabel = 'Ver más',
  index = 0,
  external = false,
  current = false,
} = Astro.props;
const eager = index < 4;
const Tag = current ? 'div' : 'a';
---
<Tag
  class:list={['cat-card', { 'cat-card--current': current }]}
  href={current ? undefined : href}
  target={!current && external ? '_blank' : undefined}
  rel={!current && external ? 'noopener nofollow' : undefined}
  aria-current={current ? 'page' : undefined}
>
  <div class="cat-card__media">
    <img
      src={image}
      alt={imageAlt}
      width="640"
      height="400"
      loading={eager ? 'eager' : 'lazy'}
      decoding="async"
      fetchpriority={index === 0 ? 'high' : undefined}
    />
    {current ? (
      <span class="cat-card__badge cat-card__badge--here">Estás aquí</span>
    ) : (
      badge && <span class="cat-card__badge">{badge}</span>
    )}
  </div>
  <div class="cat-card__body">
    <h3>{title}</h3>
    <p>{desc}</p>
    {chips.length > 0 && (
      <div class="cat-card__chips">
        {chips.map((c) => <span class="chip">{c}</span>)}
      </div>
    )}
    <span class="cat-card__cta">
      {current ? 'Estás viendo esta familia' : ctaLabel}
      {!current && (
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      )}
    </span>
  </div>
</Tag>

<style>
  .cat-card {
    display: flex;
    flex-direction: column;
    background: var(--color-white);
    border: var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    color: var(--color-dark);
    transition: box-shadow 0.22s ease, transform 0.22s ease, border-color 0.22s ease;
    height: 100%;
  }
  a.cat-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
    border-color: rgb(200 16 46 / 0.35);
  }

  /* Estado: la familia que ya estás viendo */
  .cat-card--current {
    border-color: var(--color-primary);
    background: var(--color-light);
  }
  .cat-card--current .cat-card__media { opacity: 0.55; }
  .cat-card--current .cat-card__cta { color: var(--color-gray-soft); font-weight: 700; }

  .cat-card__media {
    position: relative;
    aspect-ratio: 16 / 10;
    background: var(--color-light);
    overflow: hidden;
    border-bottom: var(--border);
  }
  .cat-card__media img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
  a.cat-card:hover .cat-card__media img { transform: scale(1.04); }
  .cat-card__badge {
    position: absolute;
    top: 0.7rem;
    left: 0.7rem;
    background: var(--color-accent);
    color: var(--color-dark);
    font-size: 0.68rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.28rem 0.6rem;
    border-radius: 2px;
  }
  .cat-card__badge--here { background: var(--color-primary); color: var(--color-white); }

  .cat-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.25rem 1.3rem 1.4rem;
    flex: 1;
  }
  h3 { margin: 0; font-size: var(--fs-h3); }
  p { margin: 0; color: var(--color-gray); font-size: 0.88rem; line-height: 1.55; flex: 1; }
  .cat-card__chips { display: flex; flex-wrap: wrap; gap: 0.32rem; }
  .cat-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.35rem;
    padding-top: 0.85rem;
    border-top: var(--border);
    color: var(--color-primary);
    font-weight: 800;
    font-size: 0.85rem;
  }
  .cat-card__cta svg { transition: transform 0.22s ease; }
  a.cat-card:hover .cat-card__cta svg { transform: translateX(4px); }
</style>
