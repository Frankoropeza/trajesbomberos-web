---
// Header: todo el menú —escritorio, panel desplegable y versión
// móvil— se genera desde NAV en site.ts, una sola fuente.
// CTA de conversión "Cotizar" siempre visible a la derecha.
import { SITE, NAV, CONTACT, WA_MESSAGES } from '@config/site';
import { waUrl } from '@lib/wa';
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href.startsWith('/') && !href.includes('#') && path.startsWith(href);
---
<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label={SITE.name}>
      <span class="brand-mark" aria-hidden="true">
        <svg width="34" height="34" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><rect width="32" height="32" rx="4" fill="#c8102e"/><path d="M16 6c2 4-2 5-1 8 .5 1.6 2 2 2 2s3-2 2-6c3 2.5 5 6 5 9.5A8.5 8.5 0 0 1 16 28a8.5 8.5 0 0 1-8-8.5C8 13 12 8.5 16 6z" fill="#ffc72c"/></svg>
      </span>
      <span class="brand-text">
        <span class="brand-name">{SITE.name}<span class="brand-tld">.com</span></span>
        <span class="brand-claim">{CONTACT.cobertura}</span>
      </span>
    </a>

    <nav class="nav-desktop" aria-label="Navegación principal">
      <ul class="nav-list">
        {NAV.map((item) => (
          <li class:list={['nav-item', { 'nav-item--has-menu': !!item.children }]}>
            <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
              {item.label}
              {item.children && (
                <svg class="nav-caret" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
              )}
            </a>
            {item.children && (
              <div class="nav-panel">
                <ul>
                  {item.children.map((c) => (
                    <li><a href={c.href}>{c.label}</a></li>
                  ))}
                </ul>
              </div>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <div class="header-actions">
      <a class="header-phone" href={`tel:${CONTACT.telefonoHref}`}>
        <span class="header-phone__label">Llámanos</span>
        <span class="header-phone__num">{CONTACT.telefono}</span>
      </a>
      <a class="btn header-cta" href={waUrl(WA_MESSAGES.cotizar)} target="_blank" rel="noopener nofollow">Cotizar</a>
    </div>

    <button class="nav-toggle" aria-expanded="false" aria-controls="mob-menu" aria-label="Abrir menú">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="mob-menu" id="mob-menu" hidden>
    <ul class="mob-list">
      {NAV.map((item) => (
        <li class="mob-item">
          <a class="mob-item__link" href={item.href}>{item.label}</a>
          {item.children && (
            <ul class="mob-sub">
              {item.children.map((c) => (
                <li><a class="mob-item__link mob-item__link--sub" href={c.href}>{c.label}</a></li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
    <div class="mob-actions">
      <a class="btn btn--wa mob-direct" href={waUrl(WA_MESSAGES.cotizar)} target="_blank" rel="noopener nofollow">Cotizar por WhatsApp</a>
      <a class="btn btn--ghost mob-direct" href={`tel:${CONTACT.telefonoHref}`}>Llamar {CONTACT.telefono}</a>
      <p class="mob-horario">{CONTACT.horario}</p>
    </div>
  </div>
</header>

<script>
  const toggle = document.querySelector('.nav-toggle');
  const menu = document.getElementById('mob-menu');
  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    if (menu) menu.hidden = open;
  });
  menu?.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).closest('a')) {
      toggle?.setAttribute('aria-expanded', 'false');
      if (menu) menu.hidden = true;
    }
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgb(255 255 255 / 0.94);
    backdrop-filter: saturate(180%) blur(10px);
    border-bottom: var(--border);
  }
  .header-inner {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2.5vw, 3rem);
    min-height: var(--header-height);
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    color: var(--color-dark);
    text-decoration: none;
    flex-shrink: 0;
  }
  .brand-mark { display: flex; }
  .brand-text { display: flex; flex-direction: column; line-height: 1.15; }
  .brand-name { font-weight: 800; font-size: 1.22rem; letter-spacing: var(--tracking-tight); }
  .brand-tld { color: var(--color-primary); }
  .brand-claim {
    font-size: 0.68rem;
    color: var(--color-gray-soft);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }

  .nav-desktop { flex: 1; }
  .nav-list { display: flex; gap: clamp(0.8rem, 1.6vw, 1.8rem); list-style: none; margin: 0; padding: 0; }
  .nav-item { position: relative; }
  .nav-item > a {
    display: inline-flex;
    align-items: center;
    gap: 0.28rem;
    padding-block: 0.5rem;
    color: var(--color-gray);
    text-decoration: none;
    font-weight: 700;
    font-size: 0.88rem;
    white-space: nowrap;
  }
  .nav-item > a:hover,
  .nav-item > a[aria-current='page'] { color: var(--color-primary); }
  .nav-caret { transition: transform 0.18s ease; }
  .nav-item--has-menu:hover .nav-caret { transform: rotate(180deg); }

  /* Panel desplegable */
  .nav-panel {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: -0.9rem;
    min-width: 260px;
    background: var(--color-white);
    border: var(--border);
    border-top: 3px solid var(--color-primary);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    padding: 0.5rem;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s;
    z-index: 20;
  }
  .nav-item--has-menu:hover .nav-panel,
  .nav-item--has-menu:focus-within .nav-panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .nav-panel ul { list-style: none; margin: 0; padding: 0; }
  .nav-panel a {
    display: block;
    padding: 0.6rem 0.8rem;
    border-radius: var(--radius);
    color: var(--color-dark);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
  }
  .nav-panel a:hover { background: var(--color-light); color: var(--color-primary); }
  .nav-panel li:last-child a {
    margin-top: 0.3rem;
    border-top: var(--border);
    border-radius: 0;
    color: var(--color-primary);
    font-weight: 800;
  }

  .header-actions { display: flex; align-items: center; gap: 1.2rem; flex-shrink: 0; }
  .header-phone { display: flex; flex-direction: column; text-decoration: none; line-height: 1.2; }
  .header-phone__label {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-gray-soft);
    font-weight: 700;
  }
  .header-phone__num { font-weight: 800; color: var(--color-dark); font-size: 0.95rem; }
  .header-cta { padding: 0.7rem 1.5rem; }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: 0;
    padding: 0.6rem;
    margin-left: auto;
    cursor: pointer;
  }
  .nav-toggle span { width: 24px; height: 3px; background: var(--color-dark); border-radius: 2px; }

  .mob-menu { background: var(--color-white); border-top: var(--border); padding: 1rem var(--container-px) 1.5rem; }
  .mob-list { list-style: none; margin: 0 0 1rem; padding: 0; }
  .mob-item__link {
    text-decoration: none;
    color: var(--color-dark);
    font-weight: 700;
    border-bottom: var(--border);
  }
  .mob-sub { list-style: none; margin: 0; padding: 0 0 0.4rem 0.9rem; border-left: 2px solid var(--color-gray-light); }
  .mob-item__link--sub { font-weight: 600; font-size: 0.9rem; color: var(--color-gray); border-bottom: 0; }
  .mob-actions { display: grid; gap: 0.6rem; }
  .mob-horario { text-align: center; color: var(--color-gray); font-size: 0.85rem; margin: 0.25rem 0 0; }

  @media (max-width: 1180px) {
    .nav-desktop, .header-actions { display: none; }
    .nav-toggle { display: flex; }
  }
</style>
