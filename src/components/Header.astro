---
// Header: todo el menú (escritorio y móvil) se genera desde NAV
// en site.ts (SSoT). CTA de conversión "Cotizar" siempre visible.
import { SITE, NAV, CONTACT, WA_MESSAGES } from '@config/site';
import { waUrl } from '@lib/wa';
---
<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label={SITE.name}>
      <span class="brand-mark" aria-hidden="true">
        <svg width="30" height="30" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><rect width="32" height="32" rx="6" fill="#c8102e"/><path d="M16 6c2 4-2 5-1 8 .5 1.6 2 2 2 2s3-2 2-6c3 2.5 5 6 5 9.5A8.5 8.5 0 0 1 16 28a8.5 8.5 0 0 1-8-8.5C8 13 12 8.5 16 6z" fill="#ffc72c"/></svg>
      </span>
      <span class="brand-name">{SITE.name}<span class="brand-tld">.com</span></span>
    </a>

    <nav class="nav-desktop" aria-label="Navegación principal">
      <ul class="nav-list">
        {NAV.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <a class="btn header-cta" href={waUrl(WA_MESSAGES.cotizar)} target="_blank" rel="noopener">Cotizar</a>

    <button class="nav-toggle" aria-expanded="false" aria-controls="mob-menu" aria-label="Abrir menú">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="mob-menu" id="mob-menu" hidden>
    <ul class="mob-list">
      {NAV.map((item) => (
        <li class="mob-item"><a class="mob-item__link" href={item.href}>{item.label}</a></li>
      ))}
    </ul>
    <div class="mob-actions">
      <a class="btn btn--wa mob-direct" href={waUrl(WA_MESSAGES.cotizar)} target="_blank" rel="noopener">Cotizar por WhatsApp</a>
      <a class="btn btn--ghost mob-direct" href={`tel:${CONTACT.telefonoHref}`}>Llamar</a>
      <p class="mob-horario">{CONTACT.horario}</p>
    </div>
  </div>
</header>

<script>
  const toggle = document.querySelector('.nav-toggle');
  const menu = document.getElementById('mob-menu');
  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    if (menu) menu.hidden = open;
  });
  menu?.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).closest('a')) {
      toggle?.setAttribute('aria-expanded', 'false');
      if (menu) menu.hidden = true;
    }
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-white);
    box-shadow: var(--shadow);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    min-height: var(--header-height);
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-weight: 800;
    font-size: 1.2rem;
    color: var(--color-dark);
    text-decoration: none;
  }
  .brand-mark { display: flex; }
  .brand-tld { color: var(--color-primary); }
  .nav-list { display: flex; gap: 1.35rem; list-style: none; margin: 0; padding: 0; }
  .nav-list a { color: var(--color-dark); text-decoration: none; font-weight: 600; font-size: 0.95rem; }
  .nav-list a:hover { color: var(--color-primary); }
  .header-cta { padding: 0.55rem 1.2rem; }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: 0;
    padding: 0.6rem;
    cursor: pointer;
  }
  .nav-toggle span { width: 24px; height: 3px; background: var(--color-dark); border-radius: 2px; }

  .mob-menu { background: var(--color-white); border-top: 1px solid var(--color-gray-light); padding: 1rem var(--container-px) 1.5rem; }
  .mob-list { list-style: none; margin: 0 0 1rem; padding: 0; }
  .mob-item__link { text-decoration: none; color: var(--color-dark); font-weight: 600; border-bottom: 1px solid var(--color-gray-light); }
  .mob-actions { display: grid; gap: 0.6rem; }
  .mob-horario { text-align: center; color: var(--color-gray); font-size: 0.85rem; margin: 0.25rem 0 0; }

  @media (max-width: 1024px) {
    .nav-desktop, .header-cta { display: none; }
    .nav-toggle { display: flex; }
  }
</style>
