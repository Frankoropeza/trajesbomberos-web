---
// L3 · Ficha de familia: /trajes/<slug>/
// La página solo resuelve la ruta; toda la secuencia de módulos
// vive en ProductLayout para que las seis queden homologadas.
import type { GetStaticPaths } from 'astro';
import ProductLayout from '@layouts/ProductLayout.astro';
import { FAMILIAS } from '@lib/familias';

export const getStaticPaths = (() => {
  return FAMILIAS.map((f) => ({ params: { slug: f.slug }, props: { familia: f } }));
}) satisfies GetStaticPaths;

const { familia } = Astro.props;
---
<ProductLayout familia={familia} />
