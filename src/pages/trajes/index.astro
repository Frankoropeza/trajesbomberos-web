---
// L2 · Índice de sección "Trajes".
// Aquí viven los módulos completos de las 6 familias (la home solo
// lleva las cards, para no duplicar contenido y no canibalizar).
// Cada módulo cierra enlazando a su L3: /trajes/<slug>/
import PageLayout from '@layouts/PageLayout.astro';
import SectionHeading from '@components/SectionHeading.astro';
import CategoryCard from '@components/CategoryCard.astro';
import CategoryFeature from '@components/CategoryFeature.astro';
import RiskGuide from '@components/RiskGuide.astro';
import FAQWithContact from '@components/FAQWithContact.astro';
import CTABanner from '@components/CTABanner.astro';
import { PRESET_CONTACTO } from '@lib/cta-presets';
import { SITE, PRODUCT_CATEGORIES } from '@config/site';
import { FAMILIAS } from '@lib/familias';
import PostCard from '@components/PostCard.astro';
import { getPosts, postUrl, readingTime } from '@lib/blog';

const path = '/trajes/';

// Franja de secciones de ESTA página
const menuItems = [
  { label: 'Las seis familias', href: '#familias' },
  { label: 'Comparativa', href: '#comparar' },
  { label: 'Preguntas', href: '#faq' },
  { label: 'Blog', href: '#blog' },
  { label: 'Anatomía del traje', href: '/#anatomia' },
  { label: 'Normas', href: '/#normas' },
];

// Keywords propias de esta página (regla de las 3 keywords)
const keywords = ['tipos de trajes para bomberos', 'catálogo', 'México'] as const;
const title = 'Tipos de trajes para bomberos | catálogo | México';
const description =
  'Tipos de trajes para bomberos: estructural, brigadista, forestal, aproximación, entrada y extricación. Cuál corresponde a cada operación y cómo se especifica.';

const guiaColumns = ['Familia', 'Para qué operación', 'Construcción', 'Complementos'];
const guiaRows = [
  ['Estructural', 'Incendio en edificaciones, ataque interior', 'Tres capas: exterior + barrera de humedad + barrera térmica', 'Casco, monja, botas, guantes, ERA'],
  ['Brigadista', 'Conato de incendio en industria, primera respuesta', 'Menor gramaje y alcance de protección que el estructural', 'Casco, guantes, botas, escafandra'],
  ['Forestal', 'Incendio de vegetación, jornadas largas en campo', 'Una sola capa de tela ignífuga inherente, ligera y transpirable', 'Casco forestal, goggles, guantes, botas sin puntera'],
  ['Aproximación', 'Trabajo cerca de calor radiante: ARFF, refinería, colada', 'Exterior aluminizado, uso prolongado, movilidad conservada', 'Capucha aluminizada, guantes, botas'],
  ['Entrada', 'Ingreso breve a la flama: horno, incidente térmico severo', 'Aluminizado multicapa, pesado, uso corto de emergencia', 'Conjunto completo con ERA'],
  ['Extricación', 'Rescate vehicular y técnico', 'Ligero, resistente a corte y punción, barrera contra patógenos', 'Guante de extricación, casco, goggles'],
];
const guiaNote =
  'Un traje de aproximación no sirve para entrar a la flama, y uno de entrada no sirve para operación prolongada. Confundirlos es el error más peligroso del sector: si tienes duda de qué familia necesita tu operación, escríbenos antes de cotizar.';

const faqs = [
  {
    q: '¿Cuántos tipos de trajes para bomberos hay?',
    a: 'En el mercado mexicano se manejan seis familias que no son intercambiables: estructural, brigadista, forestal, aproximación, entrada y extricación. Cada una responde a un riesgo distinto: elegir por precio y no por operación es lo que provoca la mayoría de los problemas.',
  },
  {
    q: '¿Cuál es la diferencia entre un traje estructural y uno de brigadista?',
    a: 'El alcance de protección. El estructural lleva tres capas y está pensado para ataque interior en una edificación en llamas. El de brigadista está pensado para conato de incendio en industria: primera respuesta, control con extintor y evacuación. Se parecen a la vista y cuestan muy distinto.',
  },
  {
    q: '¿Puedo usar un traje forestal para un incendio estructural?',
    a: 'No. El forestal es de una sola capa, sin barrera de humedad ni barrera térmica: está diseñado para jornadas largas en línea de fuego, no para el calor y el vapor de un interior. Al revés tampoco: un estructural en línea forestal provoca golpe de calor.',
  },
  {
    q: '¿Qué diferencia hay entre aproximación y entrada?',
    a: 'Aproximación es para trabajar cerca del calor radiante de forma prolongada, conservando movilidad. Entrada permite el ingreso breve a la flama y es multicapa, pesado y de uso corto. Comprar uno pensando que hace lo del otro es el error más peligroso del catálogo.',
  },
  {
    q: '¿Necesito un traje distinto para rescate vehicular?',
    a: 'Es muy recomendable. El de extricación resiste corte y punción y trae barrera contra patógenos, y evita que contamines y desgastes el traje estructural en salidas que no son de incendio. Considerando que el estructural se retira a los diez años de fabricado, cuidarlo tiene un valor económico directo.',
  },
  {
    q: '¿Venden por pieza o solo el conjunto completo?',
    a: 'Las dos formas. Puedes pedir solo chaquetón, solo pantalonera o el conjunto completo, sin compra mínima. Si combinas piezas de distintos cortes conviene revisarlo con nosotros: la interfaz entre chaquetón y pantalón es zona crítica.',
  },
];

// Lectura recomendada antes de decidir familia
const ultimosPosts = (await getPosts()).slice(0, 3);

const directoryItems = PRODUCT_CATEGORIES.map((c) => ({
  name: c.nombre,
  url: `${SITE.url}/trajes/${c.slug}/`,
}));
---
<PageLayout
  pageType="directorio"
  path={path}
  title={title}
  description={description}
  keywords={keywords}
  menuItems={menuItems}
  crumbLabel="Trajes"
  eyebrow="Catálogo por tipo de riesgo"
  h1="Tipos de trajes para bomberos"
  h1Accent="y cuál necesita tu operación"
  lead="Estructural, brigadista, forestal, aproximación, entrada y extricación. Seis familias que no son intercambiables y que responden a seis riesgos distintos."
  meta={['6 familias de traje', 'Comparativa técnica', 'Sin compra mínima', 'Envíos a los 32 estados']}
  descRight={[
    'Elegir mal la familia de traje es el error más caro del sector, y casi siempre ocurre por comparar precios entre equipos que no protegen para lo mismo. Aquí está cada familia explicada con el criterio con el que se especifica en una requisición: qué construcción lleva, para qué operación está pensada y en qué caso conviene otra.',
    'Cotizamos con ficha técnica desde el primer mensaje, sobre la norma vigente —NFPA 1970, la que sustituyó a la NFPA 1971— y con factura CFDI. Sin compra mínima: por pieza o conjunto completo, con envíos a los 32 estados.',
  ]}
  faqs={faqs}
  directoryItems={directoryItems}
>
  <!-- Índice rápido de las 6 familias -->
  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Las seis familias"
        title="Empieza por identificar tu operación"
        description="Si ya sabes cuál necesitas, entra directo a su ficha. Si no, la tabla comparativa de más abajo te ubica en un minuto."
      />
      <div class="grid-cards grid-cards--3">
        {PRODUCT_CATEGORIES.map((cat, i) => (
          <CategoryCard
            href={`/trajes/${cat.slug}/`}
            image={cat.image}
            imageAlt={cat.imageAlt}
            title={cat.nombre}
            desc={cat.desc}
            badge={cat.badge}
            chips={[...cat.chips]}
            ctaLabel="Ver ficha"
            index={i}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Módulos completos: todos idénticos, sin zig-zag -->
  <section class="section section--alt" id="familias">
    <div class="container">
      <SectionHeading
        eyebrow="A fondo"
        title="Cada familia, explicada de frente"
        description="Sin adornos: para qué está hecha, qué se le pide en una cotización y en qué caso conviene otra."
      />
      {FAMILIAS.map((f) => (
        <div class="familia">
          <CategoryFeature
            eyebrow={f.eyebrow}
            title={f.title}
            description={f.description}
            features={f.features}
            brands={f.brands}
            images={f.images}
            ctaLabel={`Ver ${f.nombreWa.toLowerCase()}`}
            ctaHref={`/trajes/${f.slug}/`}
          />
        </div>
      ))}
    </div>
  </section>

  <!-- Comparativa -->
  <section class="section" id="comparar">
    <div class="container">
      <SectionHeading
        eyebrow="Comparativa"
        title="Qué familia corresponde a tu operación"
        description="La misma tabla que usamos por teléfono cuando alguien no sabe por dónde empezar."
      />
      <RiskGuide columns={guiaColumns} rows={guiaRows} note={guiaNote} ctaLabel="Preguntar cuál me corresponde" />
    </div>
  </section>

  <!-- FAQ de la sección -->
  <section class="section section--alt" id="faq">
    <div class="container">
      <SectionHeading
        eyebrow="Preguntas frecuentes"
        title="Dudas que salen siempre al elegir traje"
      />
      <FAQWithContact items={faqs} />
    </div>
  </section>


  <!-- Blog técnico: interlinking al contenido editorial -->
  <section class="section " id="blog">
    <div class="container">
      <SectionHeading
        eyebrow="Blog técnico"
        title="Antes de decidir, léete esto"
        description="Las guías que resuelven las dudas que aparecen justo antes de emitir una requisición: qué familia toca, qué norma citar y qué datos hacen comparable una cotización."
      />
      <div class="grid-cards grid-cards--3">
        {ultimosPosts.map((a, i) => (
          <PostCard
            href={postUrl(a)}
            title={a.data.title}
            resumen={a.data.resumen}
            categoria={a.data.categoria}
            fecha={a.data.fecha}
            lectura={readingTime(a.body)}
            destacado={a.data.destacado}
            index={i}
          />
        ))}
      </div>
      <p class="blog-cta"><a href="/blog/">Ver todos los artículos del blog →</a></p>
    </div>
  </section>

  <CTABanner variant="dark" {...PRESET_CONTACTO} />
</PageLayout>

<style>
  .blog-cta { margin: 2.2rem 0 0; }
  .blog-cta a { font-weight: 800; text-decoration: none; font-size: 1.02rem; }
  .blog-cta a:hover { text-decoration: underline; }
  .familia {
    padding-block: clamp(2.2rem, 3.5vw, 3.4rem);
    border-top: var(--border);
  }
  .familia:first-of-type { border-top: 0; padding-top: 0; }
  .familia:last-of-type { padding-bottom: 0; }
</style>
