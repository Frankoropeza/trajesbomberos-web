---
// L1 · Home — arquitectura de asesor experto, no de catálogo.
// Orden: qué vendemos → cómo está hecho → cómo se especifica →
// qué se hace mal → quién lo fabrica → cómo elegir → qué exige la
// ley → cuánto dura → quién compra → quiénes somos → proceso → FAQ.
//
// Reglas duras aplicadas (estudio de mercado jul-2026):
//  · Normas VIGENTES: NFPA 1970 (absorbió 1971), NFPA 1950
//    (absorbió 1977), NFPA 1850 (absorbió 1851 y 1852),
//    NOM-017-STPS-2024 (sustituyó a la de 2008).
//  · NO se afirma que la Ley General de Protección Civil exija
//    certificación NFPA: es FALSO (verificado en el texto vigente).
//  · Marcas SOLO como referencia técnica, sin afirmar distribución.
//  · Sin precios (decisión de negocio). Sin reseñas fabricadas.
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import SectionMenu from '@components/SectionMenu.astro';
import SectionHeading from '@components/SectionHeading.astro';
import CategoryCard from '@components/CategoryCard.astro';
import CategoryFeature from '@components/CategoryFeature.astro';
import SegmentCards from '@components/SegmentCards.astro';
import SuitAnatomy from '@components/SuitAnatomy.astro';
import SpecChecklist from '@components/SpecChecklist.astro';
import MistakeList from '@components/MistakeList.astro';
import BrandGrid from '@components/BrandGrid.astro';
import TrustBar from '@components/TrustBar.astro';
import RiskGuide from '@components/RiskGuide.astro';
import NormsTable from '@components/NormsTable.astro';
import ProcessSteps from '@components/ProcessSteps.astro';
import FAQWithContact from '@components/FAQWithContact.astro';
import FactList from '@components/FactList.astro';
import {
  SITE,
  PRODUCT_CATEGORIES,
  COMPLEMENTOS,
  MARCAS_TRAJE,
  MARCAS_MATERIAL,
  WA_MESSAGES,
} from '@config/site';
import { waUrl } from '@lib/wa';

const hero = {
  eyebrow: 'Especialistas en ropa de protección contra incendios',
  title: 'Trajes para bombero',
  accent: 'en todo México',
  subtitle:
    'Estructural, brigadista, forestal, aproximación, entrada y extricación. Chaquetón y pantalonera con el composite que pide tu operación. Cotiza por WhatsApp y recibe en tu estación.',
  descRight: [
    'Nos dedicamos a una sola cosa: el traje. Equipamos brigadas industriales obligadas por la NOM-002-STPS-2010, cuerpos de bomberos y unidades de protección civil que compran por licitación, y cuerpos voluntarios que reponen pieza por pieza.',
    'Aquí abajo está, abierto, lo que un buen proveedor debería explicarte antes de venderte: cómo está hecho un traje, cómo se especifica y qué errores salen caros.',
  ],
};

const pilares = [
  { icon: 'shield' as const, title: 'Solo trajes', desc: 'Una sola especialidad. No vendemos de todo un poco.' },
  { icon: 'doc' as const, title: 'Ficha técnica por partida', desc: 'Composite, TPP, THL y norma por escrito antes de que compres.' },
  { icon: 'chat' as const, title: 'Norma vigente, no la de hace 8 años', desc: 'Trabajamos sobre NFPA 1970, que sustituyó a la NFPA 1971.' },
  { icon: 'pin' as const, title: 'Cobertura nacional', desc: 'Envíos a estación, base o domicilio en cualquier estado.' },
];

const hechos = [
  { label: 'Especialidad', value: '6 familias de traje' },
  { label: 'Cobertura', value: 'Los 32 estados' },
  { label: 'Comprobante', value: 'Factura CFDI 4.0' },
  { label: 'Compra mínima', value: 'Sin mínimo: por pieza o conjunto' },
];

const spotlight = {
  eyebrow: 'Antes de cotizar',
  title: 'Brigadista y estructural no son lo mismo (y ahí está el error más caro)',
  description:
    'Es la confusión más común y la más costosa del sector. Un equipo de brigadista está pensado para fuego incipiente en industria; un traje estructural certificado está pensado para entrar a una edificación en llamas. Se ven parecidos, cuestan muy distinto y no protegen igual.',
  features: [
    'El estructural lleva las tres capas obligatorias; el de brigadista, no necesariamente',
    'La certificación es del conjunto completo, no de la tela por separado',
    'El alcance de uso lo define la operación, no el presupuesto disponible',
    'Un traje de brigadista en ataque interior es una lesión esperando ocurrir',
  ],
  brands: ['Chaquetón', 'Pantalonera', 'Barrera térmica', 'Barrera de humedad', 'DRD'],
  images: [
    { src: '/images/productos/traje-estructural-chaqueton-pantalon-bombero.svg', alt: 'Traje estructural de bombero con chaquetón y pantalón' },
    { src: '/images/productos/traje-brigadista-industrial-bombero.svg', alt: 'Traje de brigadista industrial' },
    { src: '/images/productos/monja-capucha-barrera-particulas-bombero.svg', alt: 'Monja barrera de partículas' },
  ],
};

const guiaColumns = ['Familia', 'Para qué operación', 'Construcción', 'Complementos'];
const guiaRows = [
  ['Estructural', 'Incendio en edificaciones, ataque interior', 'Tres capas: exterior + barrera de humedad + barrera térmica', 'Casco, monja, botas, guantes, ERA'],
  ['Brigadista', 'Fuego incipiente en industria, primera respuesta', 'Menor gramaje y alcance de protección que el estructural', 'Casco, guantes, botas, escafandra'],
  ['Forestal', 'Incendio de vegetación, jornadas largas en campo', 'Una sola capa de tela ignífuga inherente, ligera y transpirable', 'Casco forestal, goggles, guantes, botas sin puntera'],
  ['Aproximación', 'Trabajo cerca de calor radiante: ARFF, refinería, colada', 'Exterior aluminizado, uso prolongado, movilidad conservada', 'Capucha aluminizada, guantes, botas'],
  ['Entrada', 'Ingreso breve a la flama: horno, incidente térmico severo', 'Aluminizado multicapa, pesado, uso corto de emergencia', 'Conjunto completo con ERA'],
  ['Extricación', 'Rescate vehicular y técnico', 'Ligero, resistente a corte y punción, barrera contra patógenos', 'Guante de extricación, casco, goggles'],
];
const guiaNote =
  'Un traje de aproximación no sirve para entrar a la flama, y uno de entrada no sirve para operación prolongada. Confundirlos es el error más peligroso del sector: si tienes duda de qué familia necesita tu operación, escríbenos antes de cotizar.';

const normasColumns: [string, string, string] = ['Referencia', 'Qué exige realmente', 'Estatus en México'];
const normasRows: [string, string, string][] = [
  [
    'NOM-017-STPS-2024',
    'Obliga al patrón a analizar riesgos por puesto, proporcionar el EPP sin costo, capacitar y supervisar. No define desempeño del traje.',
    'Obligatoria. Vigente desde el 28-sep-2025; sustituyó a la NOM-017-STPS-2008.',
  ],
  [
    'NOM-002-STPS-2010',
    'Cláusula 5.9: dotar de EPP a los integrantes de la brigada contra incendio, conforme a la NOM-017 vigente.',
    'Obligatoria en centros de trabajo con brigada.',
  ],
  [
    'NFPA 1970 (ed. 2025)',
    'Desempeño del conjunto estructural y de proximidad. Absorbió a NFPA 1971, 1975, 1981 y 1982.',
    'Referencia técnica voluntaria. Se vuelve exigible cuando un pliego de licitación la incorpora.',
  ],
  [
    'NFPA 1950 (ed. 2025)',
    'EPP forestal, rescate técnico y emergencias médicas. Absorbió a NFPA 1977, 1951 y 1999.',
    'Referencia técnica voluntaria.',
  ],
  [
    'NFPA 1850 (ed. 2026)',
    'Selección, cuidado y mantenimiento: inspección, lavado y retiro del equipo. Absorbió a NFPA 1851 y 1852.',
    'Referencia técnica voluntaria; define el ciclo de servicio del traje.',
  ],
  [
    'EN 469:2020',
    'Equivalente europeo para ropa de extinción, con Nivel 1 y Nivel 2.',
    'Referencia para equipo de origen europeo.',
  ],
];
const normasNote =
  'Precisión que conviene tener clara: en México no existe una NOM ni una NMX de producto para trajes de bombero, y la Ley General de Protección Civil no exige certificación NFPA. NFPA es referencia técnica voluntaria que se vuelve contractualmente exigible cuando la incorpora un pliego de licitación. Las licitaciones mexicanas todavía suelen redactar "NFPA 1971 Edición 2018": podemos documentar la correspondencia con NFPA 1970, capítulos 5 a 9.';

const vidaUtilColumns: [string, string, string] = ['Actividad', 'Frecuencia', 'Quién puede hacerlo'];
const vidaUtilRows: [string, string, string][] = [
  ['Inspección de rutina', 'Al inicio de turno y después de cada uso', 'El propio bombero'],
  ['Inspección avanzada', 'Anual (y a los 3 años aunque el traje no se haya estrenado)', 'Fabricante, personal capacitado o proveedor de servicio verificado'],
  ['Lavado avanzado', 'Dos veces cada 12 meses y tras exposición a productos de combustión', 'Con lavadora extractora; nunca lavadora de carga superior'],
  ['Retiro de servicio', 'Máximo 10 años desde la fecha de fabricación', 'Aplica aunque el traje nunca se haya usado'],
];
const vidaUtilNote =
  'El reloj corre desde la fecha de FABRICACIÓN impresa en la etiqueta, no desde la compra ni desde la puesta en servicio. Por eso conviene revisar esa fecha antes de aceptar inventario: comprar equipo viejo te come años de vida útil pagados.';

const pasos = [
  { title: 'Cuéntanos', desc: 'Qué operación cubres, cuántos elementos y con qué presupuesto trabajas.' },
  { title: 'Definimos', desc: 'Qué familia de traje corresponde y qué composite debe llevar.' },
  { title: 'Tallas', desc: 'Guía de tallas del fabricante y toma de medidas antes de pedir.' },
  { title: 'Cotización', desc: 'Documento formal con partidas, ficha técnica, norma y condiciones.' },
  { title: 'Entrega', desc: 'Facturamos, enviamos a cualquier estado y damos seguimiento.' },
];

const faqs = [
  {
    q: '¿Cuál es la norma vigente para trajes de bombero?',
    a: 'NFPA 1970, edición 2025. Absorbió a la NFPA 1971 junto con las normas 1975, 1981 y 1982; los requisitos del traje estructural son hoy sus capítulos 5 a 9. Muchas licitaciones todavía redactan "NFPA 1971 Edición 2018" y podemos documentar la correspondencia entre ambas.',
  },
  {
    q: '¿La ley mexicana obliga a comprar equipo certificado NFPA?',
    a: 'No. En México no existe NOM ni NMX de producto para trajes de bombero, y la Ley General de Protección Civil no exige certificación NFPA. Lo que sí es obligatorio es la NOM-017-STPS-2024, que obliga a proporcionar EPP adecuado sin costo, y la NOM-002-STPS-2010 para brigadas. NFPA se vuelve exigible cuando un pliego de licitación la incorpora al contrato.',
  },
  {
    q: '¿Qué diferencia hay entre un traje de brigadista y uno estructural?',
    a: 'El alcance de protección. El estructural lleva tres capas obligatorias (exterior, barrera de humedad y barrera térmica) y está pensado para ataque interior en edificaciones. El de brigadista está pensado para fuego incipiente en industria. Se parecen a la vista y cuestan muy distinto. Te decimos cuál corresponde a tu operación antes de cotizar.',
  },
  {
    q: '¿Qué son TPP y THL, y por qué importan?',
    a: 'TPP mide la protección térmica y THL la capacidad de disipar calor del cuerpo. Los mínimos de referencia NFPA son TPP 35 y THL 205. Buscar el TPP más alto posible es un error: si el THL queda bajo, aumenta el estrés térmico, que es la principal causa de lesión no traumática en incendio. Las licitaciones más exigentes fijan ambos valores como criterio de descalificación.',
  },
  {
    q: '¿Cuánto dura un traje estructural?',
    a: 'Bajo NFPA 1850, el retiro es a los 10 años desde la fecha de fabricación, incluso si el traje nunca se usó. Además requiere inspección avanzada anual y dos lavados avanzados por año. Revisa siempre la fecha de fabricación en la etiqueta antes de aceptar un pedido.',
  },
  {
    q: '¿Qué es el DRD y por qué debe traerlo el chaquetón?',
    a: 'Drag Rescue Device: un arnés integrado que permite arrastrar a un elemento inconsciente sin improvisar. Forma parte de los requisitos del conjunto estructural desde la edición 2008 de la norma. Si una oferta no lo menciona, pregúntalo explícitamente.',
  },
  {
    q: '¿Puedo comprar solo el chaquetón o solo la pantalonera?',
    a: 'Sí. Vendemos por pieza o conjunto completo, sin compra mínima. Ten en cuenta que la interfaz entre chaquetón y pantalón es una zona crítica: si combinas piezas de distintos cortes o tallas, conviene revisarlo con nosotros antes.',
  },
  {
    q: '¿Qué necesito para una licitación o compra de gobierno?',
    a: 'Normalmente ficha técnica en formato de licitación, certificado de laboratorio del conjunto, carta de distribuidor autorizado, CFDI 4.0 con las partidas correspondientes y acta de entrega-recepción. Preparamos el expediente y asistimos a junta de aclaraciones.',
  },
  {
    q: '¿Manejan marcas específicas?',
    a: 'Trabajamos con producto de fabricantes nacionales e importados. Dinos qué marca o qué composite pide tu pliego o tu área de compras y te confirmamos disponibilidad, tiempo de entrega y documentación.',
  },
];

const directoryItems = PRODUCT_CATEGORIES.map((c) => ({
  name: c.nombre,
  url: `${SITE.url}/#catalogo`,
}));
---
<BaseLayout pageType="home" path="/" faqs={faqs} directoryItems={directoryItems}>
  <Hero {...hero} />
  <SectionMenu />
  <TrustBar pilares={[...pilares]} />

  <!-- 1 · Qué vendemos: 6 familias de traje -->
  <section class="section section--alt" id="catalogo">
    <div class="container">
      <SectionHeading
        eyebrow="Trajes"
        title="Seis familias de traje para seis tipos de riesgo"
        description="Nos especializamos en ropa de protección para bombero. Cada familia responde a una operación distinta y no son intercambiables."
      />
      <div class="grid-cards">
        {PRODUCT_CATEGORIES.map((cat, i) => (
          <CategoryCard
            href={waUrl(WA_MESSAGES.categoria(cat.nombre))}
            external
            image={cat.image}
            imageAlt={cat.imageAlt}
            title={cat.nombre}
            desc={cat.desc}
            badge={cat.badge}
            chips={[...cat.chips]}
            ctaLabel="Cotizar"
            index={i}
          />
        ))}
      </div>

      <div class="complementos">
        <p class="complementos__intro">
          <strong>Complementos del conjunto.</strong> No son nuestra línea, pero los cotizamos junto al traje
          para cerrar el equipamiento del elemento:
        </p>
        <ul class="complementos__list">
          {COMPLEMENTOS.map((c) => (
            <li><strong>{c.nombre}</strong> — {c.nota}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- 2 · Cómo está hecho: las tres capas -->
  <section class="section" id="anatomia">
    <div class="container">
      <SectionHeading
        eyebrow="Anatomía del traje"
        title="Tres capas, y la que más protege no es la que se ve"
        description="Un traje estructural es un composite de tres materiales distintos. Saber qué hace cada capa es lo que separa una compra informada de una compra por color y precio."
      />
      <SuitAnatomy />
    </div>
  </section>

  <!-- 3 · Brigadista vs estructural -->
  <section class="section section--alt">
    <div class="container">
      <CategoryFeature
        {...spotlight}
        ctaLabel="Que me asesoren antes de comprar"
        ctaHref={waUrl(WA_MESSAGES.informacion)}
        external
      />
    </div>
  </section>

  <!-- 4 · Cómo se especifica -->
  <section class="section" id="especificar">
    <div class="container">
      <SectionHeading
        eyebrow="Cómo especificar"
        title="Los ocho datos que debe traer la ficha antes de que firmes"
        description="Cópialos en tu requisición o en tu pliego. Si una oferta no puede darte los ocho, todavía no es una oferta comparable."
      />
      <SpecChecklist />
    </div>
  </section>

  <!-- 5 · Errores de compra -->
  <section class="section section--alt" id="errores">
    <div class="container">
      <SectionHeading
        eyebrow="Errores caros"
        title="Lo que más se hace mal al comprar traje"
        duo={[
          'Siete errores que vemos repetirse en compras de gobierno, de industria y de cuerpos voluntarios. Ninguno tiene que ver con el presupuesto: todos tienen que ver con la información que faltó en el momento de decidir.',
          'Están aquí abiertos aunque no nos compres. Si detectas alguno en una oferta que estás evaluando, ya te sirvió la visita.',
        ]}
      />
      <MistakeList />
    </div>
  </section>

  <!-- 6 · Marcas: referencia técnica, NO distribución -->
  <section class="section" id="marcas">
    <div class="container">
      <SectionHeading
        eyebrow="Marcas"
        title="Quién fabrica y qué se especifica en el mercado"
        description="Referencia técnica para que redactes tu pliego o tu requisición. Dinos qué marca o qué composite te pide tu área de compras y te confirmamos disponibilidad, tiempo de entrega y documentación."
      />
      <BrandGrid titulo="Fabricantes de traje" marcas={MARCAS_TRAJE} />
      <BrandGrid titulo="Materiales del composite" marcas={MARCAS_MATERIAL} />
      <p class="marcas__nota">
        Esta lista es orientativa del mercado y no implica representación exclusiva. Dos precisiones que
        conviene tener a la mano al comparar ofertas: Globe, Cairns y Bristol pertenecen hoy a MSA Safety,
        y Morning Pride dejó de ser de Honeywell en mayo de 2025, cuando el negocio pasó a PIP. La
        certificación, en todos los casos, corresponde al conjunto terminado y al fabricante que lo lista
        ante el organismo certificador — nunca a la tela por separado.
      </p>
    </div>
  </section>

  <!-- 7 · Guía de selección -->
  <section class="section section--alt" id="guia">
    <div class="container">
      <SectionHeading
        eyebrow="Cómo elegir"
        title="Qué familia corresponde a tu operación"
        description="Seis familias para seis tipos de riesgo. No son intercambiables y elegir mal cuesta caro, en dinero y en seguridad."
      />
      <RiskGuide columns={guiaColumns} rows={guiaRows} note={guiaNote} ctaLabel="Preguntar cuál me corresponde" />
    </div>
  </section>

  <!-- 8 · Normas -->
  <section class="section" id="normas">
    <div class="container">
      <SectionHeading
        eyebrow="Normas"
        title="Qué es obligatorio en México y qué es referencia técnica"
        description="La confusión entre ambas cosas está en casi todos los sitios del sector. Aquí está la distinción, con la norma vigente en cada caso."
      />
      <NormsTable columns={normasColumns} rows={normasRows} note={normasNote} />
    </div>
  </section>

  <!-- 9 · Vida útil -->
  <section class="section section--alt" id="vida-util">
    <div class="container">
      <SectionHeading
        eyebrow="Vida útil y servicio"
        title="El traje tiene fecha de retiro, aunque se vea nuevo"
        description="NFPA 1850 define el ciclo de servicio del equipo estructural: inspección, lavado y retiro obligatorio. Presupuestarlo desde la compra evita sorpresas."
      />
      <NormsTable columns={vidaUtilColumns} rows={vidaUtilRows} note={vidaUtilNote} />
    </div>
  </section>

  <!-- 10 · Quién compra -->
  <section class="section" id="segmentos">
    <div class="container">
      <SectionHeading
        eyebrow="Quién compra"
        title="Tres compradores, tres procesos distintos"
        description="Una brigada industrial, un cuerpo de bomberos que licita y un voluntario que repone una pieza no compran igual. Entra por la ruta que te corresponde."
      />
      <SegmentCards />
    </div>
  </section>

  <!-- 11 · La empresa -->
  <section class="section section--alt" id="nosotros">
    <div class="container">
      <SectionHeading
        eyebrow="La empresa"
        title="Una sola especialidad: el traje"
        duo={[
          'Vendemos ropa de protección para bombero: trajes estructurales, de brigadista, forestales, de aproximación, de entrada y de extricación. No intentamos venderte de todo un poco; los complementos los cotizamos para cerrar el conjunto, pero el traje es lo que dominamos. Envíos a todo México.',
          'Asesoría técnica antes de la venta: qué familia corresponde a tu operación, qué capas debe llevar el composite, cómo tomar tallas y qué documentación necesita tu expediente de compra. Todo por escrito: cotización, ficha técnica y factura.',
        ]}
      />
      <FactList facts={hechos} />
    </div>
  </section>

  <!-- 12 · Proceso -->
  <section class="section section--dark" id="proceso">
    <div class="container">
      <SectionHeading
        dark
        eyebrow="Cómo trabajamos"
        title="De tu mensaje al equipo entregado"
      />
      <ProcessSteps pasos={pasos} />
    </div>
  </section>

  <!-- 13 · FAQ + contacto -->
  <section class="section" id="faq">
    <div class="container">
      <SectionHeading
        eyebrow="Preguntas frecuentes"
        title="Lo que conviene saber antes de cotizar"
      />
      <FAQWithContact items={faqs} />
    </div>
  </section>
</BaseLayout>

<style>
  .complementos {
    margin-top: 2.5rem;
    padding-top: 1.8rem;
    border-top: var(--border);
  }
  .complementos__intro { margin: 0 0 1rem; color: var(--color-gray); max-width: 72ch; }
  .complementos__list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.7rem 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .complementos__list li {
    position: relative;
    padding-left: 1.1rem;
    font-size: 0.88rem;
    color: var(--color-gray);
  }
  .complementos__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55rem;
    width: 5px;
    height: 5px;
    background: var(--color-primary);
  }
  .complementos__list strong { color: var(--color-dark); }
  .marcas__nota {
    margin: 2rem 0 0;
    padding-top: 1.4rem;
    border-top: var(--border);
    font-size: 0.86rem;
    color: var(--color-gray);
    max-width: 92ch;
  }
  @media (max-width: 900px) { .complementos__list { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .complementos__list { grid-template-columns: 1fr; } }
</style>
