const directoryItems = PRODUCT_CATEGORIES.map((c) => ({
  name: c.nombre,
  url: `${SITE.url}/#catalogo`,
}));
---
<BaseLayout pageType="home" path="/" faqs={faqs} directoryItems={directoryItems}>
  <Hero {...hero} />
  <SectionMenu />
  <TrustBar pilares={[...pilares]} />

  <!-- 1 · Qué vendemos: 6 familias de traje -->
  <section class="section section--alt" id="catalogo">
    <div class="container">
      <SectionHeading
        eyebrow="Trajes"
        title="Seis familias de trajes para bomberos, una por tipo de riesgo"
        description="Nos especializamos en ropa de protección para bombero. Cada familia responde a una operación distinta y no son intercambiables."
      />
      <div class="grid-cards grid-cards--3">
        {PRODUCT_CATEGORIES.map((cat, i) => (
          <CategoryCard
            href={waUrl(WA_MESSAGES.categoria(cat.nombre))}
            external
            image={cat.image}
            imageAlt={cat.imageAlt}
            title={cat.nombre}
            desc={cat.desc}
            badge={cat.badge}
            chips={[...cat.chips]}
            ctaLabel="Cotizar"
            index={i}
          />
        ))}
      </div>

      <!-- Un módulo por familia, en el mismo orden que las cards.
           flip alterna para dar ritmo visual entre módulos seguidos. -->
      {SPOTLIGHTS.map((s, i) => (
        <div class="spotlight-wrap">
          <CategoryFeature
            eyebrow={s.eyebrow}
            title={s.title}
            description={s.description}
            features={s.features}
            brands={s.brands}
            images={s.images}
            flip={i % 2 === 1}
            ctaLabel={`Cotizar ${s.slug.toLowerCase()}`}
            ctaHref={waUrl(WA_MESSAGES.categoria(s.slug))}
            external
          />
        </div>
      ))}

      <div class="complementos">
        <p class="complementos__intro">
          <strong>Complementos del conjunto.</strong> No son nuestra línea, pero los cotizamos junto al traje
          para cerrar el equipamiento del elemento:
        </p>
        <ul class="complementos__list">
          {COMPLEMENTOS.map((c) => (
            <li><strong>{c.nombre}</strong> — {c.nota}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- 2 · Cómo está hecho: las tres capas -->
  <section class="section" id="anatomia">
    <div class="container">
      <SectionHeading
        eyebrow="Anatomía del traje"
        title="Tres capas, y la que más protege no es la que se ve"
        description="Un traje estructural es un composite de tres materiales distintos. Saber qué hace cada capa es lo que separa una compra informada de una compra por color y precio."
      />
      <SuitAnatomy />
    </div>
  </section>

  <!-- 3 · Cómo se especifica -->
  <section class="section section--alt" id="especificar">
    <div class="container">
      <SectionHeading
        eyebrow="Cómo especificar"
        title="Los ocho datos que debe traer la ficha antes de que firmes"
        description="Cópialos en tu requisición o en tu pliego. Si una oferta no puede darte los ocho, todavía no es una oferta comparable."
      />
      <SpecChecklist />
    </div>
  </section>

  <!-- 5 · Errores de compra -->
  <section class="section" id="errores">
    <div class="container">
      <SectionHeading
        eyebrow="Errores caros"
        title="Lo que más se hace mal al comprar un traje para bombero"
        duo={[
          'Siete errores que vemos repetirse en compras de gobierno, de industria y de cuerpos voluntarios. Ninguno tiene que ver con el presupuesto: todos tienen que ver con la información que faltó en el momento de decidir.',
          'Están aquí abiertos aunque no nos compres. Si detectas alguno en una oferta que estás evaluando, ya te sirvió la visita.',
        ]}
      />
      <MistakeList />
    </div>
  </section>

  <!-- 6 · Marcas: referencia técnica, NO distribución -->
  <section class="section section--alt" id="marcas">
    <div class="container">
      <SectionHeading
        eyebrow="Marcas"
        title="Marcas de trajes para bomberos: quién fabrica y qué se especifica"
        description="Referencia técnica para que redactes tu pliego o tu requisición. Dinos qué marca o qué composite te pide tu área de compras y te confirmamos disponibilidad, tiempo de entrega y documentación."
      />
      <BrandGrid titulo="Fabricantes de traje" marcas={MARCAS_TRAJE} />
      <BrandGrid titulo="Materiales del composite" marcas={MARCAS_MATERIAL} />
      <p class="marcas__nota">
        Esta lista es orientativa del mercado y no implica representación exclusiva. Dos precisiones que
        conviene tener a la mano al comparar ofertas: Globe, Cairns y Bristol pertenecen hoy a MSA Safety,
        y Morning Pride dejó de ser de Honeywell en mayo de 2025, cuando el negocio pasó a PIP. La
        certificación, en todos los casos, corresponde al conjunto terminado y al fabricante que lo lista
        ante el organismo certificador — nunca a la tela por separado.
      </p>
    </div>
  </section>

  <!-- 7 · Guía de selección -->
  <section class="section" id="guia">
    <div class="container">
      <SectionHeading
        eyebrow="Cómo elegir"
        title="Qué familia corresponde a tu operación"
        description="Seis familias para seis tipos de riesgo. No son intercambiables y elegir mal cuesta caro, en dinero y en seguridad."
      />
      <RiskGuide columns={guiaColumns} rows={guiaRows} note={guiaNote} ctaLabel="Preguntar cuál me corresponde" />
    </div>
  </section>

  <!-- 8 · Normas -->
  <section class="section section--alt" id="normas">
    <div class="container">
      <SectionHeading
        eyebrow="Normas"
        title="Qué es obligatorio en México y qué es referencia técnica"
        description="La confusión entre ambas cosas está en casi todos los sitios del sector. Aquí está la distinción, con la norma vigente en cada caso."
      />
      <NormsTable columns={normasColumns} rows={normasRows} note={normasNote} />
    </div>
  </section>

  <!-- 9 · Vida útil -->
  <section class="section" id="vida-util">
    <div class="container">
      <SectionHeading
        eyebrow="Vida útil y servicio"
        title="El traje tiene fecha de retiro, aunque se vea nuevo"
        description="NFPA 1850 define el ciclo de servicio del equipo estructural: inspección, lavado y retiro obligatorio. Presupuestarlo desde la compra evita sorpresas."
      />
      <NormsTable columns={vidaUtilColumns} rows={vidaUtilRows} note={vidaUtilNote} />
    </div>
  </section>

  <!-- 10 · Quién compra -->
  <section class="section section--alt" id="segmentos">
    <div class="container">
      <SectionHeading
        eyebrow="Quién compra"
        title="Tres compradores, tres procesos distintos"
        description="Una brigada industrial, un cuerpo de bomberos que licita y un voluntario que repone una pieza no compran igual. Entra por la ruta que te corresponde."
      />
      <SegmentCards />
    </div>
  </section>

  <!-- 11 · La empresa -->
  <section class="section" id="nosotros">
    <div class="container">
      <SectionHeading
        eyebrow="La empresa"
        title="Una sola especialidad: el traje"
        duo={[
          'Vendemos ropa de protección para bombero: trajes estructurales, de brigadista, forestales, de aproximación, de entrada y de extricación. No intentamos venderte de todo un poco; los complementos los cotizamos para cerrar el conjunto, pero el traje es lo que dominamos. Envíos a todo México.',
          'Asesoría técnica antes de la venta: qué familia corresponde a tu operación, qué capas debe llevar el composite, cómo tomar tallas y qué documentación necesita tu expediente de compra. Todo por escrito: cotización, ficha técnica y factura.',
        ]}
      />
      <FactList facts={hechos} />
    </div>
  </section>

  <!-- 12 · Proceso -->
  <section class="section section--dark" id="proceso">
    <div class="container">
      <SectionHeading
        dark
        eyebrow="Cómo trabajamos"
        title="De tu mensaje al equipo entregado"
      />
      <ProcessSteps pasos={pasos} />
    </div>
  </section>

  <!-- 13 · FAQ + contacto -->
  <section class="section" id="faq">
    <div class="container">
      <SectionHeading
        eyebrow="Preguntas frecuentes"
        title="Lo que conviene saber antes de cotizar"
      />
      <FAQWithContact items={faqs} />
    </div>
  </section>
</BaseLayout>

